  .mon-feature-list--limit li::before { color: var(--coral); }
  .mon-dash { color: var(--gray); text-align: center; font-size: 1rem; }
  .mon-same { font-style: italic; color: var(--gray); font-size: 0.78rem; }

  .mon-conversion-banner {
    display: flex;
    align-items: center;
    gap: 20px;
    background: var(--sage-pale);
    border: 1.5px solid rgba(143,166,142,0.3);
    border-radius: 14px;
    padding: 20px 28px;
    margin: 24px 0 0;
