<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Wellness Companion — Noviana Bana Fitrah</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Lato:wght@300;400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  /* ============================================
     CSS VARIABLES & RESET
  ============================================ */
  :root {
    --sage: #8FA68E;
    --sage-light: #b8cbb7;
    --sage-pale: #e8f0e8;
    --coral: #F4A09C;
    --coral-light: #f9cbc9;
    --cream: #FAF9F6;
    --cream-dark: #F0EDE7;
    --charcoal: #2D3436;
    --gray: #636E72;
    --gray-light: #B2BEC3;
    --white: #FFFFFF;

    --font-display: 'DM Serif Display', Georgia, serif;
    --font-body: 'DM Sans', 'Lato', sans-serif;

    --nav-h: 64px;
    --section-pad: 100px;
    --max-w: 1140px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--cream);
    color: var(--charcoal);
    font-size: 17px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* Grain texture overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  /* ============================================
     NAV
  ============================================ */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--nav-h);
    background: rgba(250,249,246,0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(143,166,142,0.18);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
  }

  .nav-brand {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--charcoal);
    text-decoration: none;
    letter-spacing: 0.01em;
  }

  .nav-brand span { color: var(--sage); }

  .nav-links {
    display: flex;
    gap: 36px;
    list-style: none;
  }

  .nav-links a {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gray);
    text-decoration: none;
    transition: color 0.2s;
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -3px; left: 0; right: 0;
    height: 1.5px;
    background: var(--coral);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .nav-links a:hover { color: var(--charcoal); }
  .nav-links a:hover::after { transform: scaleX(1); }

  .nav-cta {
    background: var(--sage);
    color: var(--white) !important;
    padding: 8px 20px;
    border-radius: 100px;
    font-size: 0.75rem !important;
    font-weight: 600 !important;
    letter-spacing: 0.05em !important;
    transition: background 0.2s !important;
  }

  .nav-cta:hover { background: #7a9479 !important; }
  .nav-cta::after { display: none !important; }

  /* ============================================
     HERO
  ============================================ */
  #hero {
    min-height: 100vh;
    padding-top: var(--nav-h);
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .hero-bg-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
    pointer-events: none;
  }

  .hero-bg-blob-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, var(--sage-pale), transparent);
    top: -100px; right: -100px;
  }

  .hero-bg-blob-2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, var(--coral-light), transparent);
    bottom: 50px; right: 200px;
  }

  .hero-left {
    padding: 80px 64px 80px 80px;
    position: relative;
    z-index: 2;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sage);
    background: var(--sage-pale);
    border: 1px solid rgba(143,166,142,0.3);
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 32px;
    opacity: 0;
    animation: fadeUp 0.7s ease 0.2s forwards;
  }

  .hero-tag::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--sage);
    border-radius: 50%;
    animation: pulse 2s ease infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.4); }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    line-height: 1.08;
    color: var(--charcoal);
    margin-bottom: 12px;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.35s forwards;
  }

  .hero-title em {
    font-style: italic;
    color: var(--sage);
  }

  .hero-subtitle-line {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    line-height: 1.08;
    color: var(--coral);
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.45s forwards;
  }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.75;
    max-width: 440px;
    margin-bottom: 40px;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.55s forwards;
  }

  .hero-meta {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 48px;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.65s forwards;
  }

  .hero-meta-row {
    display: flex;
    gap: 40px;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero-stat-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray-light);
  }

  .hero-stat-value {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--charcoal);
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    align-items: center;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.75s forwards;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--charcoal);
    color: var(--white);
    padding: 14px 28px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-decoration: none;
    transition: all 0.25s;
  }

  .btn-primary:hover {
    background: var(--sage);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(143,166,142,0.35);
  }

  /* ── Scroll CTA ── */
  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(5px); }
  }

  @keyframes arrowSlide {
    0%   { transform: translateY(0); opacity: 1; }
    49%  { transform: translateY(18px); opacity: 0; }
    50%  { transform: translateY(-18px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  @keyframes pulseRing {
    0%   { box-shadow: 0 0 0 0 rgba(143,166,142,0.45); }
    70%  { box-shadow: 0 0 0 14px rgba(143,166,142,0); }
    100% { box-shadow: 0 0 0 0 rgba(143,166,142,0); }
  }

  .btn-scroll-cta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    background: var(--charcoal);
    color: var(--white);
    padding: 14px 20px 14px 28px;
    border-radius: 100px;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    animation: pulseRing 2.2s ease-in-out 1.5s infinite;
    transition: background 0.25s, transform 0.2s;
  }

  .btn-scroll-cta:hover {
    background: var(--sage);
    transform: translateY(-2px);
    animation: none;
    box-shadow: 0 10px 32px rgba(143,166,142,0.35);
  }

  .bsc-text { white-space: nowrap; }

  .bsc-arrow-wrap {
    width: 32px; height: 32px;
    background: rgba(255,255,255,0.12);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    position: relative;
  }

  .btn-scroll-cta:hover .bsc-arrow-wrap {
    background: rgba(255,255,255,0.2);
  }

  .bsc-arrow-track {
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: arrowSlide 1.6s ease-in-out 1.5s infinite;
  }

  .bsc-svg {
    flex-shrink: 0;
    display: block;
    color: var(--white);
    animation: scrollBounce 1.6s ease-in-out 1.5s infinite;
  }

  .bsc-svg--ghost {
    position: absolute;
    top: calc(100% + 4px);
  }

  /* Keep old classes so nothing breaks */
  .btn-read-project, .btn-read-arrow { display: none; }

  .product-name {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--charcoal);
    line-height: 1.2;
  }

  .hero-right {
    padding: 80px 80px 80px 20px;
    position: relative;
    z-index: 2;
    opacity: 0;
    animation: fadeIn 1.1s ease 0.5s forwards;
  }

  .hero-card {
    background: var(--white);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(45,52,54,0.1), 0 2px 8px rgba(45,52,54,0.04);
    position: relative;
  }

  .hero-card-header {
    background: linear-gradient(135deg, var(--sage-pale) 0%, #f0ede8 100%);
    padding: 20px 36px;
  }

  .hero-card-header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .beta-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sage);
    border: 1.5px solid var(--sage);
    padding: 4px 10px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .hero-card-body {
    padding: 28px 36px 36px;
  }

  .insight-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
    margin-bottom: 20px;
  }

  .insight-item {
    background: var(--cream);
    border-radius: 12px;
    padding: 16px;
    border: 1px solid var(--cream-dark);
  }

  .insight-num {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--sage);
    line-height: 1;
    margin-bottom: 4px;
  }

  .insight-label {
    font-size: 0.72rem;
    color: var(--gray);
    font-weight: 500;
    line-height: 1.3;
  }

  .outcome-bar {
    background: var(--cream-dark);
    border-radius: 12px;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .outcome-bar-text {
    font-size: 0.85rem;
    color: var(--charcoal);
    font-weight: 500;
  }

  .outcome-bar-pct {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--coral);
    white-space: nowrap;
  }

  .progress-bar-wrap {
    flex: 1;
    height: 6px;
    background: var(--cream);
    border-radius: 100px;
    overflow: hidden;
    margin: 0 12px;
  }

  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--coral), var(--sage));
    border-radius: 100px;
    width: 60%;
    animation: growBar 1.2s ease 1s both;
  }

  @keyframes growBar {
    from { width: 0; }
    to { width: 60%; }
  }

  /* ============================================
     HERO FEATURE CARD
  ============================================ */
  .hero-feature-row {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 0;
  }

  .hero-feature-icon {
    width: 36px; height: 36px;
    background: var(--sage-pale);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .hero-feature-content {
    flex: 1;
    min-width: 0;
  }

  .hero-feature-title {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: 3px;
  }

  .hero-feature-desc {
    font-size: 0.76rem;
    color: var(--gray);
    line-height: 1.5;
  }

  .hero-feature-divider {
    height: 1px;
    background: var(--cream-dark);
    margin: 0 -36px;
  }

  .hero-feature-screens {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .hero-mini-screen {
    width: 44px; height: 72px;
    border-radius: 8px;
    padding: 8px 6px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    overflow: hidden;
  }

  .hero-mini-screen--light {
    background: linear-gradient(160deg, #fdf9f3, #f3ede3);
    border: 1px solid rgba(0,0,0,0.06);
  }

  .hero-mini-screen--dark {
    background: linear-gradient(160deg, #2d1b69, #1a0f40);
    border: 1px solid rgba(255,255,255,0.08);
  }

  .hero-mini-screen--insight {
    background: var(--cream);
    border: 1px solid var(--cream-dark);
    padding: 8px 6px;
    justify-content: center;
  }

  .hero-mini-screen--chat {
    background: linear-gradient(160deg, #e8f0e8, #d4e4d3);
    border: 1px solid rgba(143,166,142,0.2);
    justify-content: center;
  }

  .hms-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hms-dot--morning { background: var(--coral); }
  .hms-dot--evening { background: #f4c842; }

  .hms-bar {
    height: 5px;
    background: rgba(0,0,0,0.1);
    border-radius: 100px;
    width: 100%;
  }

  .hms-bar--short { width: 70%; }
  .hms-bar--white { background: rgba(255,255,255,0.2); }
  .hms-stars { font-size: 0.45rem; color: rgba(0,0,0,0.2); letter-spacing: -1px; }

  .hms-bubble {
    height: 10px;
    border-radius: 100px;
    margin-bottom: 4px;
  }

  .hms-bubble--ai {
    width: 85%;
    background: rgba(255,255,255,0.7);
    align-self: flex-start;
  }

  .hms-bubble--user {
    width: 65%;
    background: var(--sage);
    align-self: flex-end;
    margin-left: auto;
    opacity: 0.6;
  }

  .hms-bubble--short { width: 55%; }

  /* ============================================
     SECTION SHARED STYLES
  ============================================ */
  section {
    padding: var(--section-pad) 0;
    position: relative;
  }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 48px;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sage);
    margin-bottom: 16px;
  }

  .section-label::before {
    content: '';
    width: 24px; height: 1.5px;
    background: var(--sage);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    line-height: 1.15;
    color: var(--charcoal);
    margin-bottom: 16px;
  }

  .section-title em { font-style: italic; color: var(--sage); }
  .section-title .accent { color: var(--coral); }

  .section-intro {
    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.75;
    max-width: 600px;
    margin-bottom: 56px;
  }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.75s ease, transform 0.75s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }

  /* ============================================
     PROBLEM SECTION
  ============================================ */
  #problem {
    background: var(--charcoal);
    color: var(--white);
  }

  #problem .section-label { color: var(--coral); }
  #problem .section-label::before { background: var(--coral); }
  #problem .section-title { color: var(--white); }
  #problem .section-title em { color: var(--coral); }
  #problem .section-intro { color: rgba(255,255,255,0.55); }

  /* Persona banner */
  .persona-banner {
    display: flex;
    align-items: center;
    gap: 20px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    padding: 16px 24px;
    margin-bottom: 56px;
    flex-wrap: wrap;
  }

  .persona-banner-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--coral);
    white-space: nowrap;
  }

  .persona-banner-text {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.7);
    flex: 1;
  }

  .persona-focus-pill {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--sage-light);
    background: rgba(143,166,142,0.12);
    border: 1px solid rgba(143,166,142,0.2);
    padding: 5px 14px;
    border-radius: 100px;
    white-space: nowrap;
  }

  /* Pain point photo cards */
  .pain-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 40px;
  }

  .pain-photo-card {
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.03);
    transition: border-color 0.25s;
  }

  .pain-photo-card:hover { border-color: rgba(244,160,156,0.3); }

  .pain-photo-card--center .pain-photo-label { color: var(--sage-light); }

  .pain-photo-wrap {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    position: relative;
  }

  .pain-photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: grayscale(15%) brightness(0.88);
    transition: transform 0.4s ease, filter 0.3s;
  }

  .pain-photo-card:hover .pain-photo-wrap img {
    transform: scale(1.04);
    filter: grayscale(0%) brightness(0.95);
  }

  .pain-photo-body {
    padding: 22px 22px 24px;
  }

  .pain-photo-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--coral);
    margin-bottom: 8px;
  }

  .pain-photo-body p {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
  }

  /* ============================================
     DISCOVERY
  ============================================ */
  #discovery { background: var(--cream); }

  /* Research Slider */
  .rslider-wrap {
    margin-bottom: 20px;
    overflow: hidden;
  }

  .rslider {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .rslide {
    background: var(--white);
    border-radius: 20px;
    padding: 28px 24px;
    border: 1px solid var(--cream-dark);
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: transform 0.25s, box-shadow 0.25s;
    min-height: 220px;
  }

  .rslide:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(143,166,142,0.12);
  }

  .rslide--coral { border-top: 3px solid var(--coral); }
  .rslide--dark  { background: var(--charcoal); color: var(--white); border-color: transparent; }
  .rslide--sage  { border-top: 3px solid var(--sage); background: var(--sage-pale); }

  .rslide-num {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sage);
    margin-bottom: 4px;
  }

  .rslide--dark .rslide-num { color: var(--sage-light); }

  .rslide-tag {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gray);
    margin-bottom: 8px;
