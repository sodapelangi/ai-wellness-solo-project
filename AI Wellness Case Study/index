  .mon-conv-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sage);
    white-space: nowrap;
  }

  .mon-conv-stat {
    font-family: 'DM Serif Display', serif;
    font-size: 2.8rem;
    color: var(--sage);
    line-height: 1;
    flex-shrink: 0;
  }

  .mon-conv-desc { font-size: 0.82rem; color: var(--gray); line-height: 1.55; }

  .mon-table--econ .mon-metric-cell { font-weight: 600; color: var(--charcoal) !important; width: 28%; }
  .mon-val-cell { font-weight: 600; color: var(--charcoal) !important; white-space: nowrap; }
  .mon-val-cell--highlight { color: var(--sage) !important; }
  .mon-val-cell--green { color: #2e7d32 !important; }

  .risk-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .risk-card {
    border-radius: 16px;
    border: 1.5px solid var(--cream-dark);
    overflow: hidden;
  }

  .risk-card--critical { border-color: rgba(220,80,80,0.2); }
  .risk-card--moderate { border-color: rgba(244,160,100,0.25); }

  .risk-card-top {
    padding: 24px 26px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .risk-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
