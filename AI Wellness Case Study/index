  .comp-app-icon--headspace { background: linear-gradient(135deg, #f4a63a, #e8852a); }
  .comp-app-icon--stoic { background: var(--charcoal); font-family: var(--font-display); }

  .comp-app-name { font-size: 0.92rem; font-weight: 700; color: var(--charcoal); }
  .comp-app-cat { font-size: 0.7rem; color: var(--gray); text-transform: uppercase; font-weight: 600; letter-spacing: 0.04em; margin-top: 2px; }
  .comp-vs { font-family: var(--font-display); font-style: italic; font-size: 1.1rem; color: var(--gray-light); padding: 0 8px; }

  .comp-two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }

  .comp-col-title {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray-light);
    margin-bottom: 16px;
  }

  .comp-insight-list { display: flex; flex-direction: column; gap: 12px; }

  .comp-insight-item {
    display: flex; gap: 12px; align-items: flex-start;
