  .mon-tier-cell--premium { color: var(--sage) !important; }
  .mon-tier-sub { font-weight: 400; color: var(--gray); font-size: 0.75rem; }

  .mon-price-cell { font-weight: 700; color: var(--charcoal) !important; white-space: nowrap; }
  .mon-price-cell--premium { color: var(--sage) !important; }
  .mon-price-sub { display: block; font-weight: 400; font-size: 0.72rem; color: var(--gray); }
