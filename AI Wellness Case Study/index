    width: 100%;
    border-collapse: collapse;
    font-size: 0.83rem;
  }

  .mpt-table thead tr {
    background: var(--cream-dark);
  }

  .mpt-table th {
    padding: 12px 20px;
    text-align: left;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gray);
