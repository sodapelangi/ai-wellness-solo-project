  .smoke-screen-badge--sage    { background: var(--sage-pale); color: var(--sage); }
  .smoke-screen-badge--coral   { background: rgba(244,160,156,0.15); color: #c0635f; }

  .smoke-screen-frame {
    border-radius: 12px 12px 0 0;
    overflow: hidden;
    border: 1px solid var(--cream-dark);
    border-bottom: none;
    background: #f9f8f5;
  }

  .smoke-screen-frame img {
    width: 100%;
    display: block;
    transition: transform 0.35s ease;
  }

  .smoke-screen-col:hover .smoke-screen-frame img { transform: scale(1.02); }

  .smoke-screen-caption {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--charcoal);
    padding: 8px 12px;
    background: var(--white);
    border: 1px solid var(--cream-dark);
    border-top: none;
    border-radius: 0 0 12px 12px;
    text-align: center;
  }

  .smoke-screen-arrow {
    color: var(--gray-light);
    padding: 0 12px 32px;
    flex-shrink: 0;
  }

  .smoke-screen-vs {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray);
    padding: 0 14px 32px;
    flex-shrink: 0;
    align-self: end;
  }

