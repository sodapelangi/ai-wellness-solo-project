  .smoke-meta-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: stretch;
    background: var(--cream-dark);
    margin-top: 20px;
  }

  .smoke-meta-cell {
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .smoke-meta-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sage);
  }

  .smoke-meta-value {
    font-size: 0.8rem;
    color: var(--charcoal);
    line-height: 1.5;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .smoke-meta-divider {
    width: 1px;
    background: rgba(143,166,142,0.2);
    margin: 12px 0;
  }

  /* Real screenshot containers in smoke tests */
  .smoke-version-screen-img {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--cream-dark);
    background: var(--cream);
    margin-bottom: 10px;
  }

  .smoke-version-screen-img img {
    width: 100%;
    display: block;
    transition: transform 0.35s ease;
  }

  .smoke-version-card:hover .smoke-version-screen-img img {
    transform: scale(1.02);
  }

  .smoke-result-screen-img {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--cream-dark);
    background: var(--cream);
    margin-bottom: 16px;
  }

  .smoke-result-screen-img img {
    width: 100%;
    display: block;
    transition: transform 0.35s ease;
  }

  .smoke-result-screen-img:hover img {
    transform: scale(1.01);
  }

  .smoke-result-two-imgs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    background: transparent;
    border: none;
    padding: 0;
  }

  .smoke-result-two-imgs img {
    border-radius: 10px;
    border: 1px solid var(--cream-dark);
  }
  .comp-table-wrap {
    overflow-x: auto;
    border-radius: 12px;
    border: 1.5px solid var(--cream-dark);
  }

  .comp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
    min-width: 700px;
  }

  .comp-table thead tr {
    background: var(--charcoal);
    color: var(--white);
  }

  .comp-table th {
    padding: 12px 16px;
    text-align: left;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .comp-table td {
    padding: 12px 16px;
    vertical-align: top;
    color: var(--gray);
    border-bottom: 1px solid var(--cream-dark);
    line-height: 1.5;
  }

  .comp-table tbody tr:last-child td { border-bottom: none; }
  .comp-table tbody tr:nth-child(even) { background: var(--cream); }
  .comp-table tbody tr:hover td { background: var(--sage-pale); }

  .comp-app-cell {
    font-weight: 700;
    color: var(--charcoal) !important;
    white-space: nowrap;
  }

  .comp-block {
    background: var(--white);
    border-radius: 24px;
    padding: 40px;
    border: 1px solid var(--cream-dark);
    margin-bottom: 24px;
  }

  .comp-apps-row {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 1.5px solid var(--cream-dark);
  }

  .comp-app-badge { display: flex; align-items: center; gap: 12px; }

  .comp-app-icon {
    width: 48px; height: 48px;
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 0.9rem;
    color: var(--white); flex-shrink: 0;
