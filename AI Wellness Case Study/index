  .smoke-meta-note {
    font-size: 0.72rem;
    color: var(--sage);
    font-style: italic;
    margin-top: 6px;
    line-height: 1.5;
    padding-top: 6px;
    border-top: 1px dashed rgba(143,166,142,0.3);
