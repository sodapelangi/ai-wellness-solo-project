  .risk-mitigation-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 12px;
  }

  .risk-mitigation-items {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .risk-mitigation-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.82rem;
    color: var(--charcoal);
    line-height: 1.5;
  }

  .risk-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 5px;
  }

  .risk-dot--critical { background: #c0392b; }
  .risk-dot--moderate { background: #c07020; }

  /* AI prompt code block — warning/critical lines */
  .vcb-line--warn {
    color: #c07020;
  }

  .vcb-line--critical {
    color: #c0392b;
    background: rgba(220,80,80,0.06);
    padding: 4px 6px;
    border-radius: 4px;
    margin: 2px 0;
  }

  /* Smoke test meta note */
  .smoke-block--setup {
    padding: 0;
    overflow: hidden;
  }

  .smoke-block--setup .smoke-header {
    padding: 20px 28px;
    border-bottom: 1px solid var(--cream-dark);
  }

  /* Row 1: screens */
  .smoke-screens-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: end;
    gap: 0;
    padding: 28px 28px 0;
  }

  .smoke-screen-col {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .smoke-screen-badge {
    display: inline-block;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 100px;
    margin-bottom: 8px;
    align-self: flex-start;
  }

