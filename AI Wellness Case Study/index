  .sol-focus-block {
    background: var(--white);
    border-radius: 20px;
    padding: 32px 36px;
    border: 1px solid var(--cream-dark);
    margin-bottom: 24px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 20px 40px;
    align-items: start;
  }

