  .problem-statement-block {
    background: var(--charcoal);
    border-radius: 20px;
    padding: 40px 48px;
    position: relative;
  }

  .psb-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sage-light);
    margin-bottom: 20px;
  }

  .psb-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
